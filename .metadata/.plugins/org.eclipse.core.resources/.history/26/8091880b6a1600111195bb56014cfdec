server:
  port: 8765
spring:
  main:
    allow-bean-definition-overriding: true
  application:
    name: api-gateway
  managament:
    tracing:
      sampling:
        probability: 1.0
  zikin:
    base-url: http://localhost:9411
  cloud:
    gateway:
      server:
        webflux:
          routes:
            - id: book-service
              uri: lb://book-service
              predicates:
              - Path=/book-service/**
            - id: book-service
              uri: lb://exchange-service
              predicates:
              - Path=/exchange-service/**
springdoc:
  swagger-ui:
    urls:
    - name: book-service
      url: /book-service/v3/api-docs
    - name: exchange-service
      url: /exchange-service/v3/api-docs					