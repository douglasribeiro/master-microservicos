server:
  port: 8000
  eureka:
    client:
      service-url:
        defaultZone: http://localhost:8761/eureka
        #defaultZone: ${EUREKA_CLIENT_SERVICEURL_DEFULTZONE:http://localhost:8761/eureka}
spring:
  main:
    allow-bean-definition-overriding: true
  application:
    name: exchange-service
  datasource:
    driver-class-name: com.mysql.cj.jdbc.Driver
    url: jdbc:mysql://localhost:3308/exchange_service #?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC&enabledTLSProtocols=TLSv1.2
    username: docker
    password: admin123
  jpa:
     hibernate: 
      ddl-auto: none
     properties:
      hibernate:
      show-sql: true
      open-in-view: false
  managament:
    tracing:
      sampling:
        probability: 1.0
  zikin:
    base-url: ${SPRING_ZIPKIN_BASEURL:http://localhost:9411}			
springdoc:
  api-docs: 
    path: /exchange-service/v3/api-docs
  swagger-ui:
    url: /exchange-service/v3/api-docs      
  override-server-url: true
