server:
  port: 8100
eureka:
  client:
    service-url:
      defaultZone: http://localhost:8761/eureka
resilience4j:
  ratelimiter:
    instances:
      default:
        limit-for-period: 2
        limit-refresh-period: 10s 
  retry:
    instances:
      foo-bar:
        max-attempts: 7
        wait-duration: 1s
        enable-exponential-backoff: true
spring:
  main:
    allow-bean-definition-overriding: true
  application:
    name: book-service
  datasource:
    driver-class-name: com.mysql.cj.jdbc.Driver
    url: jdbc:mysql://localhost:3306/book_service
    username: root
    password: root
  jpa:
    hibernate: 
      ddl-auto: none
    properties:
      hibernate:
    show-sql: true
    open-in-view: false
  managament:
    tracing:
      sampling:
        probability: 1.0
springdoc:
  api-docs: 
    path: /book-service/v3/api-docs
  swagger-ui:
    url: /book-service/v3/api-docs      
  override-server-url: true