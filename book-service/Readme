1 - Criação do Jar
mvn clean package

2 - Exemplo Dockerfile

FROM eclipse-temurin:21-jdk
COPY target/*.jar app.jar
ENTRYPOINT ["java", "-jar", "/app.jar"]

docker build -t book-service:0.0.1-SNAPSHOT .

docker run -p 8100:8100 -d book-service:0.0.1-SNAPSHOT

docker tag book-service:0.0.1-SNAPSHOT 01douglas/book-service:0.0.1-SNAPSHOT

docker login docker.io

docker push 01douglas/book-service:0.0.1-SNAPSHOT

docker run -p 8101:8101 -d 01douglas/book-service:0.0.1-SNAPSHOT

docker tag 01douglas/book-service:0.0.1-SNAPSHOT 01douglas/book-service:latest

docker push 01douglas/book-service:latest