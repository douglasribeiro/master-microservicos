1 - Criação do Jar
mvn clean package

2 - Exemplo Dockerfile

FROM eclipse-temurin:21-jdk
COPY target/*.jar app.jar
ENTRYPOINT ["java", "-jar", "/app.jar"]

docker build -t api-gateway:0.0.1-SNAPSHOT .

docker run -p 80:80 -d api-gateway:0.0.1-SNAPSHOT

docker tag api-gateway:0.0.1-SNAPSHOT 01douglas/api-gateway:0.0.1-SNAPSHOT

docker login docker.io

docker push 01douglas/api-gateway:0.0.1-SNAPSHOT

docker run -p 876X:876X -d 01douglas/api-gateway:0.0.1-SNAPSHOT

docker tag api-gateway:0.0.1-SNAPSHOT 01douglas/api-gateway:latest

docker push 01douglas/api-gateway:latest